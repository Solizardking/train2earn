{
  "name": "@openclawdsolana/agent-staking",
  "version": "0.1.0",
  "description": "OpenClawd agent staking and unstaking protocol for Metaplex Core assets on Solana.",
  "license": "MIT",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "hook": "ts-node ./cli/hook.ts",
    "build": "anchor build",
    "test": "anchor test",
    "deploy:devnet": "anchor deploy --provider.cluster \"${SOLANA_RPC_URL:-https://api.devnet.solana.com}\"",
    "deploy:mainnet": "anchor deploy --provider.cluster mainnet",
    "script": "ts-node ./cli/command.ts",
    "script:devnet": "ANCHOR_PROVIDER_URL=\"${SOLANA_RPC_URL:-https://api.devnet.solana.com}\" ts-node ./cli/command.ts",
    "script:mainnet": "ANCHOR_PROVIDER_URL=\"${SOLANA_RPC_URL:-https://api.mainnet-beta.solana.com}\" ts-node ./cli/command.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@metaplex-foundation/digital-asset-standard-api": "^1.0.3",
    "@metaplex-foundation/mpl-core": "^1.0.2",
    "@metaplex-foundation/mpl-token-auth-rules": "^2.0.0",
    "@metaplex-foundation/mpl-token-metadata": "^3.2.1",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@metaplex-foundation/umi-uploader-irys": "^0.9.1",
    "@project-serum/anchor": "^0.26.0",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.91.7",
    "@types/node": "^20.12.7",
    "bs58": "^5.0.0",
    "commander": "^9.5.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
