"""
Vertex AI custom serving container for Ollama models.

Bundles selected Ollama models into a single container that exposes:
  - POST /predict  — Vertex AI prediction protocol (instances[] → predictions[])
  - POST /generate — raw Ollama generate passthrough
  - GET  /health   — Vertex health check
  - GET  /list     — list bundled models

Build args:
  MODEL_NAMES — comma-separated Ollama model tags to bake in
"""
FROM ollama/ollama:latest AS runtime

ENV OLLAMA_HOST=0.0.0.0:8080 \
    OLLAMA_ORIGINS="*" \
    MODEL_PATH=/models

# Install Python for the Vertex AI prediction shim
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv curl jq && \
    rm -rf /var/lib/apt/lists/* && \
    python3 -m pip install --no-cache-dir fastapi uvicorn[standard] httpx

WORKDIR /app

# Copy the Vertex AI prediction shim
COPY ollama_vertex_serve.py /app/ollama_vertex_serve.py
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# Models are injected at build time from GCS (downloaded in entrypoint)
# or baked in via build arg for smaller deployments
ARG MODEL_NAMES=""
ENV MODEL_NAMES=${MODEL_NAMES}

EXPOSE 8080

# Health check — Vertex pings /health
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

ENTRYPOINT ["/app/entrypoint.sh"]
</parameter>
</write_to_file>
<task_progress>- [x] Assess GCP environment and credentials
