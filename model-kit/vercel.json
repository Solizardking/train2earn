{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "register.x402.wtf"
        }
      ],
      "destination": "/register.html"
    },
    {
      "source": "/register",
      "destination": "/register.html"
    },
    {
      "source": "/models",
      "destination": "/index.html"
    },
    {
      "source": "/model-kit",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
